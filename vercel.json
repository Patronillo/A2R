  "version": 2,
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs18.x"
    },
    "api/**/*.js": {
      "runtime": "nodejs18.x"
    }
    "api/**/*.ts": { "runtime": "nodejs20.x" },
    "api/**/*.js": { "runtime": "nodejs20.x" }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
